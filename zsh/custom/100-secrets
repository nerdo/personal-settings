# Auto-export secrets from ~/.secrets/export/
# Each file's name becomes the env var, file contents become the value.
# Secrets outside export/ are for on-demand access by other apps.
if [[ -d ~/.secrets/export ]]; then
    for secret_file in ~/.secrets/export/*(-.N); do
        export "${secret_file:t}"="$(cat "$secret_file")"
    done
fi

